@startuml SequenceDiagram_LocalVectorEngine

skinparam backgroundColor white
skinparam sequenceArrowThickness 2
skinparam sequenceParticipant {
    BackgroundColor #EEF2FF
    BorderColor #3B4A9C
}
skinparam sequenceActorBackgroundColor #EEF2FF
skinparam sequenceActorBorderColor #3B4A9C
skinparam sequenceLifeLineBorderColor #3B4A9C
skinparam sequenceMessageAlign center
skinparam noteBorderColor #3B4A9C
skinparam noteBackgroundColor #FFF9E6

title LocalVectorEngine — UML Sequence Diagram\nRAG pipeline: Indexing (once) + Query (per question)

actor User
participant "Program\n(Demo host)" as P
participant "SlidingWindowChunkingService" as CHK
participant "OnnxEmbeddingService" as EMB
participant "BLiteVectorStore" as STORE
database    "BLite file\n(HNSW index, cosine,\n384-dim)" as DB

' ═════════════════════════════════════════════════════════
' PHASE 1 — INDEXING (run once per document)
' ═════════════════════════════════════════════════════════
== Phase 1 — Indexing ==

User -> P : IndexDocument(path)
activate P

P -> P : text = File.ReadAllText(path)

P -> CHK : Chunk(documentId, text, source)
activate CHK
note right of CHK
  Sliding window over words
  (default: 400 words / 50 overlap).
  Emits DocumentChunk records
  with sequential ChunkIndex.
end note
CHK --> P : IEnumerable<DocumentChunk>
deactivate CHK

loop for each chunk
    P -> EMB : EmbedAsync(chunk.Text, ct)
    activate EMB
    EMB -> EMB : 1. BERT WordPiece tokenize\n2. ONNX forward pass\n3. mean-pool (attention mask)\n4. L2 normalize
    EMB --> P : float[384]
    deactivate EMB

    P -> STORE : StoreChunkAsync(chunk, embedding, ct)
    activate STORE
    STORE -> DB : InsertAsync(VectorChunkEntity)
    DB --> STORE : (HNSW updated, BSON page written)
    STORE --> P : (ok)
    deactivate STORE
end

P --> User : N chunks indexed
deactivate P

note over User, DB #F8F9FF
    Indexing is done **once per document**.
    The HNSW index is then persistent on disk.
end note

' ═════════════════════════════════════════════════════════
' PHASE 2 — QUERY (run for every user question)
' ═════════════════════════════════════════════════════════
== Phase 2 — Query ==

User -> P : Query("...natural-language question...")
activate P

P -> EMB : EmbedAsync(question, ct)
activate EMB
EMB --> P : float[384] (L2-normalized)
deactivate EMB

P -> STORE : SearchAsync(queryEmbedding, topK=5, ct)
activate STORE

STORE -> DB : KNN over Embedding VectorSearch(query, k)
note right of DB
  HNSW approximate nearest-neighbor
  search over all stored embeddings — O(log N).
end note
DB --> STORE : IList<VectorChunkEntity>\n(ordered by similarity)

STORE -> STORE : recompute cosine score\n= dot(query, embedding)\n(vectors are already L2-normalized)

STORE --> P : IReadOnlyList<SearchResult>\n(chunk + score in [-1,1])
deactivate STORE

P --> User : Top-K passages + scores
deactivate P

note over User, DB #F8F9FF
    The retrieved passages are the **context**
    an LLM would use to produce a grounded answer
    (the LLM step is outside this engine's scope).
end note

@enduml
