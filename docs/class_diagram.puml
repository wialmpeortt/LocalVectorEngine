@startuml ClassDiagram_VerifiableNews

skinparam classAttributeIconSize 0
skinparam classFontStyle Bold
skinparam backgroundColor white
skinparam class {
    BackgroundColor #EEF2FF
    BorderColor #3B4A9C
    ArrowColor #3B4A9C
}

title Verifiable News - UML Class Diagram

' ─── Interfaces ───────────────────────────────────────────
interface IEmbeddingService {
    + GenerateEmbedding(text: string) : float[]
}

interface IVectorStore {
    + IndexChunk(chunk: DocumentChunk) : void
    + SearchAsync(queryVector: float[], topK: int) : List<DocumentChunk>
}

' ─── Core Entities ────────────────────────────────────────
class NewsArticle {
    + Id : string
    + Title : string
    + Content : string
    + SourceUrl : string
    + PublishedAt : DateTime
    + Atomize(llm: ILLMService) : List<AtomicClaim>
}

class AtomicClaim {
    + Id : string
    + Text : string
    + ArticleId : string
    + EmbeddingVector : float[]
    + Embed(service: IEmbeddingService) : void
}

class DocumentChunk {
    + Id : string
    + SourceDocumentName : string
    + Content : string
    + EmbeddingVector : float[]
    + Embed(service: IEmbeddingService) : void
}

class ClaimVerificationResult {
    + ClaimId : string
    + ClaimText : string
    + SupportingChunks : List<DocumentChunk>
    + SimilarityScores : List<float>
    + IsVerified : bool
}

' ─── Services ─────────────────────────────────────────────
interface ILLMService {
    + ExtractClaims(articleText: string) : List<AtomicClaim>
}

class OllamaLLMService {
    - modelName : string
    - endpointUrl : string
    + ExtractClaims(articleText: string) : List<AtomicClaim>
}

class OnnxEmbeddingService {
    - modelPath : string
    + GenerateEmbedding(text: string) : float[]
}

class BLiteVectorStore {
    - dbPath : string
    + IndexChunk(chunk: DocumentChunk) : void
    + SearchAsync(queryVector: float[], topK: int) : List<DocumentChunk>
}

class VerificationEngine {
    - llmService : ILLMService
    - embeddingService : IEmbeddingService
    - vectorStore : IVectorStore
    + VerifyArticle(article: NewsArticle) : List<ClaimVerificationResult>
}

' ─── Relationships ────────────────────────────────────────
NewsArticle "1" --> "1..*" AtomicClaim : atomizes >
AtomicClaim "1" --> "1" ClaimVerificationResult : produces >
ClaimVerificationResult "1" --> "0..*" DocumentChunk : supported by >

OllamaLLMService ..|> ILLMService
OnnxEmbeddingService ..|> IEmbeddingService
BLiteVectorStore ..|> IVectorStore

VerificationEngine --> ILLMService : uses
VerificationEngine --> IEmbeddingService : uses
VerificationEngine --> IVectorStore : uses

@enduml
